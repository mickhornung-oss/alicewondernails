# Alice Wonder Nails V2 Environment Template
# Copy to .env and set appropriate values.
# Do not commit .env to Git (use .gitignore protection).

# === LOCAL DEVELOPMENT (DJANGO_DEBUG=True) ===
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# PostgreSQL Local
POSTGRES_DB=alice_wonder_nails
POSTGRES_USER=alice_local
POSTGRES_PASSWORD=Passwort
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Email (Console backend for local development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.local

DJANGO_ADMIN_URL=admin/

# === PRODUCTION / STAGING (DJANGO_DEBUG=False) ===
# Required for production.py security checks to pass
# Generate a strong SECRET_KEY with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# DJANGO_SECRET_KEY=<generate-with-django-tool-50+-chars-random>

# Production ALLOWED_HOSTS (comma-separated, no spaces)
# Example: DJANGO_ALLOWED_HOSTS=example.com,www.example.com
# DJANGO_ALLOWED_HOSTS=

# Production CSRF Trusted Origins (for frontend on different domain, optional)
# Example: DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
# DJANGO_CSRF_TRUSTED_ORIGINS=

# Production HSTS Configuration (conservative defaults, increase after full testing)
# HSTS max-age in seconds (default: 3600 = 1 hour)
# DJANGO_SECURE_HSTS_SECONDS=3600
# Include subdomains (default: False, enable after subdomain verification)
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# HSTS preload (default: False, enable only after careful domain registration)
# DJANGO_SECURE_HSTS_PRELOAD=False
