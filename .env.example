# Alice Wonder Nails V1 Configuration
# Kopiere diese Datei zu .env und setze die Werte entsprechend

# Admin-Zugangsdaten
ADMIN_USERNAME=change-me
ADMIN_PASSWORD_HASH=# Generiere mit: python -c "from backend.security import hash_password; print(hash_password('dein-passwort'))"

# Session-Konfiguration
SESSION_SECRET=# Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_COOKIE_NAME=awn_admin_session
SESSION_MAX_AGE_SECONDS=28800

# Sicherheit (WICHTIG für Produktion!)
HTTPS_ONLY_SESSIONS=false  # Für lokale Entwicklung: false, für Produktion: MUSS true sein!

# CORS-Konfiguration
CORS_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$

# Rate Limiting
PUBLIC_RATE_LIMIT_PER_MINUTE=20
LOGIN_RATE_LIMIT_PER_MINUTE=10

# PRODUKTIONS-CHECKLIST:
# 1. HTTPS_ONLY_SESSIONS=true setzen
# 2. Neue, starke SESSION_SECRET generieren
# 3. Starkes Admin-Passwort setzen
# 4. CORS_ORIGIN_REGEX auf produktive Domain anpassen